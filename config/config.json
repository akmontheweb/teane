    "model_routing": {
        "planning_primary": "deepseek:deepseek-v4-pro",
        "planning_mode": "thinking",
        "planning_fallback": "deepseek:deepseek-v4-pro",
        "planning_fallback_mode": "thinking",
        "patching_primary": "deepseek:deepseek-v4-pro",
        "patching_mode": "non_thinking",
        "patching_fallback": "moonshot:kimi-k3",
        "patching_fallback_mode": "thinking",
        "repair_primary": "deepseek:deepseek-v4-pro",
        "repair_mode": "non_thinking",
        "repair_fallback": "moonshot:kimi-k3",
        "repair_fallback_mode": "thinking",
        "doc_reviewer_primary": "deepseek:deepseek-v4-pro",
        "doc_reviewer_mode": "non_thinking",
        "doc_reviewer_fallback": "deepseek:deepseek-v4-pro",
        "doc_reviewer_fallback_mode": "thinking",
        "code_reviewer_primary": "deepseek:deepseek-v4-pro",
        "code_reviewer_mode": "non_thinking",
        "code_reviewer_fallback": "deepseek:deepseek-v4-pro",
        "code_reviewer_fallback_mode": "non_thinking",
        "decomposition_primary": "deepseek:deepseek-v4-pro",
        "decomposition_mode": "thinking",
        "decomposition_fallback": "deepseek:deepseek-v4-pro",
        "decomposition_fallback_mode": "thinking",
        "decomposition_reviewer_primary": "moonshot:kimi-k3",
        "decomposition_reviewer_mode": "non_thinking",
        "decomposition_reviewer_fallback": "deepseek:deepseek-v4-pro",
        "decomposition_reviewer_fallback_mode": "non_thinking",
        "ollama_local_model": "ollama:qwen2.5-coder:14b",
        "ollama_local_backup": "",
        "force_local_only": false
    },
    "llm_dispatch": {
        "max_tokens_default": 32768,
        "max_tokens_per_role": {
            "planning": 32768,
            "patching": 32768,
            "repair": 32768,
            "doc_reviewer": 32768,
            "code_reviewer": 32768,
            "decomposition": 32768,
            "decomposition_reviewer": 8192
        },
        "continue_on_length": {
            "planning": true,
            "patching": true,
            "repair": true,
            "doc_reviewer": true,
            "code_reviewer": true
        },
        "max_continuation_cycles": 5,
        "patching_read_file_cap": 20,
        "patching_emission_rounds": 10,
        "read_file_rounds": 6,
        "prompt_cache_enabled": true
    },
    "persistence": {
        "db_path": "~/.harness/checkpoints.db",
        "ttl_days": 30
    },
    "logging": {
        "level": "INFO",
        "log_dir": "~/.harness/logs",
        "console_level": "WARNING",
        "json_stderr": false,
        "langsmith": false
    },
    "retrieval_tools": {
        "enabled": true,
        "max_results": 80,
        "max_files": 200,
        "max_bytes": 12000,
        "grep_timeout_s": 15,
        "git_timeout_s": 15,
        "list_dir_depth": 2,
        "semantic_top_k": 8,
        "git_log_max": 15
    },
    "best_of_n": {
        "enabled": false,
        "n": 3,
        "strategy": "first_success",
        "max_concurrency": 3,
        "diversity_mode": "temperature",
        "per_variant_budget_usd": null
    },
    "lintgate": {
        "format_modified_files": true,
        "strict_missing_formatter": true
    },
    "post_mortem": {
        "enabled": true,
        "max_cost_usd": 0.1,
        "retire_on_clean_run": true
    },
    "diagnostics": {
        "enabled": true,
        "timeout_seconds": 120,
        "max_rounds": 2,
        "scope": "impacted",
        "tools": {
            "pyright": true,
            "mypy": true,
            "tsc": true
        }
    },
    "security": {
        "block_on": [
            "critical",
            "high"
        ],
        "warn_on": [
            "medium"
        ],
        "ignore_below": "low",
        "scanners": [
            "gitleaks",
            "bandit",
            "semgrep",
            "trivy"
        ],
        "allowlist_rules": [
            "javascript.lang.security.detect-insecure-websocket.detect-insecure-websocket"
        ],
        "max_findings_to_route_to_repair": 10,
        "hard_ceiling_multiplier": 3
    },
    "speculative": {
        "enabled": false,
        "trigger": "after_n_repair_failures",
        "n_repair_failures_threshold": 2,
        "diversity_mode": "model",
        "cost_strategy": "cheap_first_sequential",
        "selection_strategy": "first_success",
        "salvage_strategy": "none",
        "num_variants": 3,
        "max_concurrency": 3,
        "temperature": 0.3,
        "variant_models": [],
        "variant_prompt_styles": [],
        "expensive_model": "",
        "cheap_model": "",
        "repair_fanout": false,
        "repair_fanout_variants": 3,
        "repair_fanout_after_rounds": 2,
        "voting": {
            "n_judges": 3,
            "judge_role": "code_reviewer"
        },
        "worktree_base_dir": "/tmp/.harness/speculative"
    },
    "test_generation": {
        "enabled": true,
        "max_iterations": 5,
        "property_based_tests": true
    },
    "test_regeneration": {
        "enabled": true,
        "max_attempts_per_test": 1,
        "tier_b_auto": false,
        "require_code_linkage": true,
        "coverage_nonregression": true
    },
    "traceability": {
        "enforce": true
    },
    "fanout": {
        "max_concurrency": 8,
        "timeout_seconds": 180
    },
    "metrics": {
        "burn_rate_window_minutes": 10,
        "metrics_dir": "~/.harness/metrics"
    },
    "debug": {
        "dump_llm_calls": true,
        "dump_max_files": 5000
    },
    "compiler": {
        "run_prod_import_smoke_check": true,
        "targeted_tests_first": true
    },
    "patcher": {
        "enforce_read_before_edit": true,
        "use_structured_tools": true,
        "root_files": [
            "setup.py",
            "setup.cfg",
            "pyproject.toml",
            "conftest.py",
            "manage.py",
            "__init__.py",
            "wsgi.py",
            "asgi.py",
            "main.py",
            "tox.ini",
            "pytest.ini",
            "MANIFEST.in",
            ".gitignore",
            "requirements.txt",
            "Pipfile",
            "Pipfile.lock",
            "poetry.lock",
            "uv.lock",
            ".python-version",
            "mypy.ini",
            ".mypy.ini",
            "ruff.toml",
            ".ruff.toml",
            "Makefile",
            "makefile",
            "GNUmakefile",
            "pom.xml",
            "mvnw",
            "mvnw.cmd",
            "build.gradle",
            "build.gradle.kts",
            "settings.gradle",
            "settings.gradle.kts",
            "gradle.properties",
            "gradlew",
            "gradlew.bat",
            "package.json",
            "package-lock.json",
            "yarn.lock",
            "pnpm-lock.yaml",
            "npm-shrinkwrap.json",
            "tsconfig.json",
            "tsconfig.base.json",
            "tsconfig.app.json",
            "tsconfig.node.json",
            "tsconfig.build.json",
            "tsconfig.spec.json",
            ".npmrc",
            ".nvmrc",
            ".node-version",
            ".yarnrc",
            ".yarnrc.yml",
            "pnpm-workspace.yaml",
            ".pnpmrc",
            "Dockerfile",
            "docker-compose.yml",
            "docker-compose.yaml",
            "compose.yml",
            "compose.yaml",
            "Caddyfile",
            ".env",
            ".env.example",
            ".env.local",
            ".env.development",
            ".env.production",
            ".env.test"
        ]
    },
    "web_tools": {
        "enabled": true,
        "max_bytes": 200000,
        "max_results": 5,
        "search_backend": "tavily",
        "api_key_env": "TAVILY_API_KEY",
        "allow_private_ips": false,
        "timeout_seconds": 20,
        "tool_call_cap_per_dispatch": 3,
        "backends": [
            {
                "name": "ddg-fallback",
                "enabled": true,
                "search_backend": "duckduckgo_lite",
                "api_key_env": ""
            }
        ]
    },
    "mcp": {
        "enabled": true,
        "tool_call_timeout_seconds": 30,
        "command_allowlist": [],
        "allow_local_filesystem_servers": true,
        "result_max_bytes": 200000,
        "servers": [
            {
                "name": "fetch",
                "transport": "stdio",
                "command": [
                    "uvx",
                    "mcp-server-fetch"
                ]
            },
            {
                "name": "fs",
                "transport": "stdio",
                "command": [
                    "npx",
                    "-y",
                    "@modelcontextprotocol/server-filesystem",
                    "${TEANE_MCP_FS_ROOT:-~}"
                ]
            }
        ]
    },
    "lsp": {
        "enabled": true,
        "enabled_flows": [
            "patch",
            "test"
        ],
        "request_timeout_seconds": 15,
        "python_require_venv": true,
        "prefetch_budget_seconds": 20
    },
    "skills": {
        "user_skills_dir": "~/.harness/user_skills"
    },
    "memory": {
        "enabled": true,
        "dir": "~/.harness/memory",
        "max_bytes": 100000,
        "inject_max_bytes": 8000,
        "compact_after": 60000,
        "compact_keep_recent": 3
    },
    "github": {
        "gh_path": "",
        "default_owner": "",
        "default_repo": ""
    },
    "dashboard": {
        "enabled": true,
        "host": "127.0.0.1",
        "port": 8729,
        "token_env": "",
        "writes_enabled": true,
        "csrf_token_env": "",
        "hitl_webhook_secret": "",
        "hitl_webhook_timeout_seconds": 600.0,
        "audit_log_retention_days": 90,
        "web_db_path": "~/.harness/web.db",
        "config_path": "",
        "docs_dir": "",
        "sessions_max": 200
    },
    "schedule": {
        "enabled": false,
        "tick_seconds": 60,
        "history_db": "~/.harness/schedule.db",
        "log_dir": "~/.harness/schedule_logs",
        "harness_binary": "teane",
        "jobs": []
    },
    "repo_index": {
        "enabled": false,
        "backend": "tfidf",
        "top_k": 5,
        "chunk_lines": 200,
        "chunk_overlap": 20,
        "inject_max_bytes": 4000,
        "index_dir": "~/.harness/repo_index"
    },
    "deployment_defaults": {
        "network": {
            "reverse_proxy": "none",
            "tls_strategy": "none",
            "tls_contact_email": "none",
            "public_http_port": 8000,
            "public_https_port": 9000,
            "host_port_range": [
                7999,
                9999
            ],
            "docker_network_mode": "bridge",
            "primary_domain": "localhost",
            "dns_provider": "none"
        },
        "storage": {
            "volume_root": "${TEANE_VOLUME_ROOT:-~/.harness/deploy/volumes}",
            "persistence_mode": "volume",
            "container_uid": 1000,
            "container_gid": 1000,
            "backup_destination": "none",
            "backup_path": "${TEANE_BACKUP_PATH:-~/.harness/deploy/backup}",
            "multi_host_storage": "none"
        },
        "secrets": {
            "manager": "env_file",
            "manager_endpoint": "",
            "env_file_path": ".env",
            "ci_secret_injection": "none",
            "rotation_policy_days": 0,
            "mask_in_logs": true
        },
        "infra_sync": {
            "conflict_policy": "overwrite",
            "reserved_ports": [
                22,
                5432,
                6379
            ],
            "protect_containers": [
                "legacy-db"
            ],
            "protect_volumes": [
                "legacy-data"
            ],
            "legacy_compat_mode": false
        }
    },
    "agile": true,
    "agile_defaults": {
        "batch_size": 5,
        "commit_on_story": false,
        "repair_cap": 3
    }
}
