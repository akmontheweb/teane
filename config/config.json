{
    "_help": "Every setting is documented in config_help.md (same directory).",
    "core_languages": {
        "backend_language": "Python",
        "web_language": [
            "React",
            "TypeScript",
            "TailwindCSS",
            "radix-ui"
        ]
    },
    "allow_network": true,
    "product_spec_dir": "product_spec",
    "sandbox": {
        "backend": "auto",
        "docker_image": "harness-builder:latest",
        "docker_memory_limit": "512m",
        "docker_cpu_limit": "1.0",
        "docker_pids_limit": 100,
        "readonly_cache_mounts": [
            "~/.cache/pip",
            "~/.npm",
            "~/.cache/yarn",
            "~/.pnpm-store",
            "~/.m2",
            "~/.gradle"
        ],
        "cache_volumes": false,
        "cache_volumes_prefix": "harness",
        "timeout_seconds": 300,
        "pgid_kill_on_timeout": true,
        "restore_workspace_ownership": true
    },
    "token_budget": {
        "hard_cap_usd": 10.0,
        "context_window_threshold_pct": 0.85,
        "stages": {}
    },
    "node_throttle": {
        "max_code_review_cycles": 1,
        "max_discovery_iterations": 1,
        "max_doc_review_cycles": 1,
        "max_requirement_gap_fill_cycles": 2,
        "max_patch_repair_iterations": 5,
        "max_consecutive_distraction_rounds": 3,
        "max_consecutive_low_signal_rounds": 5,
        "total_hard_cap_multiplier": 4,
        "max_end_of_session_regression_cycles": 3,
        "end_of_session_repair_diagnostic_cap": 30,
        "end_of_session_repair_inventory_cap": 150,
        "end_of_session_force_reasoning_model": true,
        "stuck_target_limit": 3,
        "generic_no_progress_limit": 5,
        "same_missing_dep_limit": 3
    },
    "hitl": {
        "requirement": false,
        "architecture": false,
        "repair": true,
        "deployment": true,
        "layout_divergence": true
    },
    "models": {
