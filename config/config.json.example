{
    "_comment": "Example canonical configuration for the AI Agent Harness. Copy this file to config.json (same directory) and adjust to taste. The real config.json is .gitignored. The harness reads ONLY this file — there are no fallback defaults, no per-workspace overrides, no auto-generated workspace configs. Validation is strict: unknown keys, typos, wrong types, missing required fields, or missing API key env vars all cause the harness to exit (code 2) BEFORE any LLM call. API keys are NEVER stored in this file — set them as env vars (ANTHROPIC_API_KEY, OPENAI_API_KEY, DEEPSEEK_API_KEY) before running. Keys for models that are declared here but NOT referenced in model_routing below are not required. Ollama (local) models need no env var.",

    "_build_command_comment": "Default shell command the sandbox runs to compile / test the workspace. The compiler_node auto-adapts this per-workspace (e.g. 'make build' → 'python3 -m pytest -q' when no Makefile is present and pyproject.toml exists). Override per-run via the --build-cmd CLI flag.",
    "build_command": "make build",

    "_allow_network_comment": "Default for whether the build sandbox is allowed network access. compiler_node auto-flips to true when the build command contains 'pip install', 'npm install', etc. Override per-run via --allow-network.",
    "allow_network": true,

    "_product_spec_dir_comment":"MANDATORY. NAME of the folder at the workspace root that holds the product specification .txt files. Must be a bare folder name — no path separators, no absolute paths, no `..`. The folder MUST live at `<workspace>/<product_spec_dir>/`. The harness reads every .txt file (alphabetical order) and consolidates them before LLM synthesis. `harness run` and `harness doctor` REFUSE to start when this key is missing, malformed, or when the named folder is missing / empty at the workspace root.",
    "product_spec_dir": "product_spec",

    "_sandbox_comment": "Build-sandbox isolation. 'backend' is the isolation strategy: 'auto' picks docker if installed else unshare(8) else bare-subprocess. 'docker_image' is the base container image (compiler_node auto-swaps to python:3.12-slim / node:20-slim / etc. based on the toolchain implied by build_command). Memory / CPU / PID limits cap container resource use. readonly_cache_mounts are host directories bind-mounted read-only into the container so package managers find their warm caches. timeout_seconds is the hard cap on a single build run. pgid_kill_on_timeout=true sends SIGKILL to the process group on timeout. restore_workspace_ownership=true causes the harness to either pass --user $UID:$GID to docker (Linux non-root host) or run a chown trailer so the bind-mounted workspace doesn't end up root-owned. cache_volumes=true swaps each readonly_cache_mounts entry for a writable Docker named volume scoped to the session id — pip/npm/cargo can then persist downloads across containers and the next compile in the session reuses them. The speculative path runs a single sequential warm-up install before variants fan out to keep the cache race-free. Use `harness cache clear` to remove the volumes. Default off for one release while we observe.",
    "sandbox": {
        "backend": "auto",
        "docker_image": "ubuntu:22.04",
        "docker_memory_limit": "512m",
        "docker_cpu_limit": "1.0",
        "docker_pids_limit": 100,
        "readonly_cache_mounts": [
            "~/.cache/pip",
            "~/.npm",
            "~/.cache/yarn",
            "~/.pnpm-store",
            "~/.cache/go-build",
            "~/.cargo/registry",
            "~/.m2",
            "~/.gradle",
            "~/.pub-cache"
        ],
        "cache_volumes": false,
        "cache_volumes_prefix": "harness",
        "timeout_seconds": 300,
        "pgid_kill_on_timeout": true,
        "restore_workspace_ownership": true
    },

    "_token_budget_comment": "Spend caps. hard_cap_usd is the per-session dollar ceiling — the gateway refuses dispatches once spend reaches it. Override per-run via --budget. context_window_threshold_pct triggers context compaction when the message list fills this fraction of the model's window. stages (optional) is a soft per-stage budget split — maps NodeRole name to a fraction of hard_cap_usd, e.g. {\"planning\":0.2,\"patching\":0.2,\"repair\":0.5,\"doc_reviewer\":0.05,\"code_reviewer\":0.05}. Today this only emits a warning when a stage exceeds its share; hard enforcement is a follow-up.",
    "token_budget": {
        "hard_cap_usd": 2.00,
        "context_window_threshold_pct": 0.85,
        "stages": {}
    },

    "_node_throttle_comment": "Per-loop iteration ceilings. max_patch_repair_iterations caps build-repair retries before HITL. max_doc_review_cycles / max_code_review_cycles cap the adversarial reviewer revisions. max_discovery_iterations caps the requirements/architecture interview loop.",
    "node_throttle": {
        "max_patch_repair_iterations": 5,
        "max_doc_review_cycles": 1,
        "max_code_review_cycles": 1,
        "max_discovery_iterations": 10
    },

    "_models_comment": "Model registry. Every LLM the harness can dispatch to must be declared here. The key (e.g. 'openai:gpt-4o-mini') is the routing handle used in model_routing below. Required fields: provider (openai/anthropic/deepseek/ollama), model_id (vendor's name), context_window. Cost fields drive the budget tracker. supports_thinking=true allows extended-thinking when a role's *_mode is 'thinking' or 'thinking_max'. supports_cache=true enables prefix-caching. api_key MUST stay empty here — set keys as env vars ({PROVIDER}_API_KEY). The gateway reads env vars at dispatch time; the api_key field is informational only.",
    "models": {
        "openai:gpt-4o": {
            "provider": "openai",
            "model_id": "gpt-4o",
            "context_window": 128000,
            "input_cost_per_1m": 2.50,
            "output_cost_per_1m": 10.00,
            "cached_input_cost_per_1m": 1.25,
            "api_base_url": "https://api.openai.com/v1",
            "supports_thinking": false,
            "api_key": "",
            "supports_cache": true
        },
        "openai:gpt-4o-mini": {
            "provider": "openai",
            "model_id": "gpt-4o-mini",
            "context_window": 128000,
            "input_cost_per_1m": 0.15,
            "output_cost_per_1m": 0.60,
            "cached_input_cost_per_1m": 0.075,
            "api_base_url": "https://api.openai.com/v1",
            "supports_thinking": false,
            "api_key": "",
            "supports_cache": true
        },
        "anthropic:claude-sonnet-4": {
            "provider": "anthropic",
            "model_id": "claude-sonnet-4-20250514",
            "context_window": 200000,
            "input_cost_per_1m": 3.00,
            "output_cost_per_1m": 15.00,
            "cached_input_cost_per_1m": 0.30,
            "api_base_url": "https://api.anthropic.com/v1",
            "supports_thinking": false,
            "api_key": "",
            "supports_cache": true
        },
        "deepseek:deepseek-v4-pro": {
            "provider": "deepseek",
            "model_id": "deepseek-v4-pro",
            "context_window": 131072,
            "input_cost_per_1m": 0.14,
            "output_cost_per_1m": 0.28,
            "cached_input_cost_per_1m": 0.014,
            "api_base_url": "https://api.deepseek.com/v1",
            "supports_thinking": true,
            "api_key": "",
            "supports_cache": true
        },
        "deepseek:deepseek-v4-flash": {
            "provider": "deepseek",
            "model_id": "deepseek-v4-flash",
            "context_window": 131072,
            "input_cost_per_1m": 0.14,
            "output_cost_per_1m": 0.28,
            "cached_input_cost_per_1m": 0.014,
            "api_base_url": "https://api.deepseek.com/v1",
            "supports_thinking": false,
            "api_key": "",
            "supports_cache": true
        },
        "ollama:qwen2.5-coder:14b": {
            "provider": "ollama",
            "model_id": "qwen2.5-coder:14b",
            "context_window": 131072,
            "input_cost_per_1m": 0.0,
            "output_cost_per_1m": 0.0,
            "api_base_url": "http://localhost:11434/v1",
            "supports_thinking": false,
            "api_key": "",
            "supports_cache": false
        }
    },

    "_model_routing_comment": "Maps the harness's internal roles to model keys from the registry above. Only models referenced here are 'active' — declared-but-unrouted models don't require a {PROVIDER}_API_KEY env var. *_primary fields are REQUIRED (planning, patching, repair) — the harness exits at startup if any is empty or references a missing model. *_fallback fires when the primary returns empty / errors. *_mode controls extended-thinking: 'thinking_max' (largest budget), 'thinking' (conservative), 'non_thinking' (off). doc_reviewer_* and code_reviewer_* are optional — empty primary disables that role. ollama_local_model + force_local_only let operators route everything to a local Ollama model for offline / cost-control use. SAME-MODEL FALLBACK: setting *_fallback to the SAME model as *_primary is a supported pattern — the cross-model escalation on the last repair attempt becomes a no-op and the same model runs in repair_mode (typically 'thinking'). Useful when the operator wants every repair attempt to use one capable reasoning model rather than escalating from a cheap one. The harness detects this case and skips the misleading 'Escalating to reasoning model' banner.",
    "model_routing": {
        "planning_primary": "deepseek:deepseek-v4-flash",
        "planning_mode": "thinking_max",
        "planning_fallback": "deepseek:deepseek-v4-pro",
        "patching_primary": "deepseek:deepseek-v4-pro",
        "patching_mode": "thinking",
        "repair_primary": "deepseek:deepseek-v4-pro",
        "repair_mode": "thinking",
        "repair_fallback": "deepseek:deepseek-v4-pro",
        "doc_reviewer_primary": "openai:gpt-4o-mini",
        "doc_reviewer_mode": "thinking",
        "doc_reviewer_fallback": "openai:gpt-4o",
        "code_reviewer_primary": "openai:gpt-4o-mini",
        "code_reviewer_mode": "thinking",
        "code_reviewer_fallback": "openai:gpt-4o",
        "ollama_local_model": "ollama:qwen2.5-coder:14b",
        "ollama_local_backup": "",
        "force_local_only": false
    },

    "_llm_dispatch_comment": "Per-call LLM dispatch parameters. max_tokens_default is the fallback ceiling on a model's response (visible content + thinking trace combined for reasoning-mode models like deepseek-v4-pro). max_tokens_per_role gives every role an explicit, tunable ceiling — operators can raise repair (thinking trace + patch blocks need headroom), lower doc_reviewer (short critiques), or tweak any other role without code changes. Any role absent from the map falls back to max_tokens_default. Values are clamped to [256, 32768] at load time — below 256 produces useless truncated replies; above 32768 blows past every supported model's per-request output cap. Recommended baselines: planning 4096, patching 8192 (initial scaffold often emits 4-6 file blocks; thinking mode eats headroom), repair 8192 (thinking trace + tracebacks + patch blocks all share the ceiling), doc_reviewer 4096, code_reviewer 8192 (deeper critiques on larger diffs). prompt_cache_enabled=true (default) makes the gateway emit Anthropic cache_control markers on the system block (+ first user message when ≥4 KB) and run prefix-stability drift detection for every cache-capable provider (OpenAI / DeepSeek auto-cache only fires when the prefix is byte-identical across calls — the gateway emits a cache_prefix_drift observability event when it isn't). Flip to false to fall back to the legacy string-form Anthropic system payload.",
    "llm_dispatch": {
        "max_tokens_default": 4096,
        "max_tokens_per_role": {
            "planning": 4096,
            "patching": 8192,
            "repair": 8192,
            "doc_reviewer": 4096,
            "code_reviewer": 8192
        },
        "prompt_cache_enabled": true
    },

    "_persistence_comment": "Where LangGraph stores session checkpoints. db_path is the SQLite file path (default: per-user). ttl_days expires checkpoints older than this on every harness run — set to 0 to disable GC.",
    "persistence": {
        "db_path": "~/.harness/checkpoints.db",
        "ttl_days": 30
    },

    "_logging_comment": "Structured logging. level is the root logger level (DEBUG/INFO/WARNING/ERROR). log_dir is where per-session JSONL log files land. json_stderr=true emits each log record as one JSON line to stderr (good for log aggregators). langsmith=true enables LangSmith tracing if LANGCHAIN_API_KEY is set.",
    "logging": {
        "level": "INFO",
        "log_dir": "~/.harness/logs",
        "json_stderr": false,
        "langsmith": false
    },

    "_lintgate_comment": "Lintgate behaviour after patches land. format_modified_files=false (default) skips the auto-formatter on pre-existing files so the harness doesn't clobber user style. Linters still run on every modified file.",
    "lintgate": {
        "format_modified_files": false
    },

    "_speculative_comment": "Configuration-driven speculative compilation (#12 rebuild). Six independent strategy axes; the shipped defaults aim for positive ROI on typical workloads. (1) trigger decides WHEN speculative engages: 'always' fires every patching pass (high cost); 'first_attempt_only' is the legacy default; 'after_n_repair_failures' (DEFAULT) holds back until sequential repair has stalled — the high-value moment; 'manual' fires only when state.force_speculative is set. n_repair_failures_threshold (default 2) is the gate for the after_n_repair_failures trigger. (2) diversity_mode decides HOW variants differ: 'temperature' spreads temps over one model (legacy); 'prompt' fixes the model but varies a per-variant system-prompt style; 'model' (DEFAULT) routes each variant through a different model from variant_models — real architectural independence beats temperature noise; 'mixed' combines models and styles. (3) cost_strategy decides the COST shape: 'equal_cost' (legacy 3x cost); 'cheap_first_sequential' (DEFAULT) dispatches the cheap_model first, then expensive_model only if needed — expected cost ~1.1x; 'cheap_parallel_then_expensive' fires all-but-one cheap and one expensive in parallel; 'all_cheap' uses cheap_model for every variant. (4) selection_strategy: 'first_pass' (DEFAULT, alias 'first_success'); 'fewest_changes'; 'voted' dispatches voting.n_judges adversarial reviewers per passing variant (reuses fanout #11) and picks the highest-vote-rate; 'all_pass' requires every variant to pass. (5) salvage_strategy: 'none' (DEFAULT — fall back to sequential repair against the untouched workspace, strictly safer than the legacy merge); 'fewest_errors'; 'voted_partial'; 'merge' (legacy behaviour; documented failure mode of incoherent workspaces). (6) num_variants ∈ [1, 10]; max_concurrency ∈ [1, 10] caps parallelism; temperature ∈ [0.0, 1.5]. variant_models is a list of model keys used by diversity_mode ∈ {model, mixed}. variant_prompt_styles is a list of styles (e.g. 'minimal-diff', 'balanced', 'thorough') or names from the built-in style library used by diversity_mode ∈ {prompt, mixed}. expensive_model + cheap_model are referenced by the cost_strategy axes. Legacy configs without the new keys auto-upgrade to {trigger: first_attempt_only, diversity_mode: temperature, cost_strategy: equal_cost, salvage_strategy: merge} with a one-time warning so existing operators see exactly today's behaviour.",
    "speculative": {
        "enabled": false,
        "trigger": "after_n_repair_failures",
        "n_repair_failures_threshold": 2,
        "diversity_mode": "model",
        "cost_strategy": "cheap_first_sequential",
        "selection_strategy": "first_pass",
        "salvage_strategy": "none",
        "num_variants": 3,
        "max_concurrency": 3,
        "temperature": 0.3,
        "variant_models": [],
        "variant_prompt_styles": [],
        "expensive_model": "",
        "cheap_model": "",
        "voting": {"n_judges": 3, "judge_role": "code_reviewer"},
        "worktree_base_dir": "/tmp/.harness/speculative"
    },

    "_test_generation_comment": "Auto-generate stack-specific unit tests for modified source files after patching. enabled=false disables the test_generation_node entirely. max_iterations caps retries.",
    "test_generation": {
        "enabled": true,
        "max_iterations": 2
    },

    "_metrics_comment": "Cost-metrics aggregation for the `harness metrics` subcommand. burn_rate_window_minutes is the rolling window for the live burn-rate gauge (clamped to [1, 1440]). metrics_dir is where --json / --prometheus outputs land.",
    "metrics": {
        "burn_rate_window_minutes": 10,
        "metrics_dir": "~/.harness/metrics"
    },

    "_debug_comment": "Observability flags for post-mortem analysis. dump_llm_calls=true writes every LLM dispatch (across all roles: planning, patching, repair, doc/code review, test generation, discovery, etc.) as a single .txt file in ~/.harness/debug containing the exact input messages and the response. dump_max_files caps directory size; oldest files (by mtime) are pruned on each write. The deprecated dump_repair_prompts key is honoured as an alias for dump_llm_calls.",
    "debug": {
        "dump_llm_calls": false,
        "dump_max_files": 5000
    },

    "_compiler_comment": "Pre-build smoke checks. run_prod_import_smoke_check=true makes compiler_node first attempt to import every production module inside the sandbox before running the actual build, so module-level errors surface as [prod-import] diagnostics ahead of any cascade-amplified test failures.",
    "compiler": {
        "run_prod_import_smoke_check": true
    },

    "_patcher_comment": "Patcher behaviour. enforce_read_before_edit=true makes the patcher reject REPLACE_BLOCK / DELETE_BLOCK / INSERT_AT_BLOCK on any file the LLM has not been shown this turn (via pre-flight content, READ_FILE results, or a prior closest-match window). Mirrors Claude Code's Read-before-Edit invariant — flip on after verifying the LLM emits READ_FILE for unfamiliar files. Drift detection (sha256 comparison) runs unconditionally whenever the host has recorded a hash.",
    "patcher": {
        "enforce_read_before_edit": false
    },

    "_web_tools_comment": "Web research tools (web_fetch + web_search) exposed to the planner LLM via text-DSL blocks like <<<WEB_FETCH url=\"...\">>> and <<<WEB_SEARCH query=\"...\">>>. enabled=false (default) keeps the skills unregistered so the harness behaves byte-identically to pre-tool runs. Flip to true to let the planner pull documentation, RFCs, and search results before deciding on an implementation. max_bytes caps response size per fetch (default 200 KB ≈ 50 K tokens). max_results caps search results. search_backend chooses the search provider — only 'duckduckgo_lite' ships today (no API key required); Tavily / Brave / SerpAPI land in a follow-up. allow_private_ips opens the SSRF guard for trusted internal targets (e.g. an internal docs portal on 10.0.0.0/8) — leave false on multi-tenant or untrusted-prompt hosts. timeout_seconds bounds each HTTP call. tool_call_cap_per_dispatch caps how many tool rounds the LLM may run inside a single graph-node call before the interceptor forces it to proceed.",
    "web_tools": {
        "enabled": false,
        "max_bytes": 200000,
        "max_results": 5,
        "search_backend": "duckduckgo_lite",
        "api_key_env": "",
        "allow_private_ips": false,
        "timeout_seconds": 20,
        "tool_call_cap_per_dispatch": 3
    },

    "_mcp_comment": "Model Context Protocol client pool. When enabled=true, each entry in 'servers' spawns as a subprocess (stdio transport — HTTP/SSE is a follow-up slice) and the harness registers each advertised tool into the SkillRegistry as mcp__<server>__<tool>. The planner / patcher / repair LLM invokes them via <<<MCP_CALL server=\"x\" tool=\"y\" args='{...}'>>> blocks intercepted in graph._run_tool_loop. Default false keeps the harness byte-identical to pre-MCP runs. tool_call_timeout_seconds bounds every JSON-RPC tools/call. command_allowlist EXTENDS the built-in safe allowlist (npx, npm, node, python, python3, uvx, pipx, docker) with operator-trusted binaries — add a binary basename here to whitelist it. allow_local_filesystem_servers gates the official @modelcontextprotocol/server-filesystem (and lookalikes) because filesystem MCP bypasses the build sandbox and grants the LLM raw host I/O — must be explicit. result_max_bytes caps each tools/call response payload pushed back into the LLM conversation (default 200 KB). servers is a list of {name, transport, command, env, api_key_env} — see harness/mcp_client.py:McpServerConfig for the per-field contract. A failed server start is logged and skipped — one bad server never blocks the rest of the pool.",
    "mcp": {
        "enabled": false,
        "tool_call_timeout_seconds": 30,
        "command_allowlist": [],
        "allow_local_filesystem_servers": false,
        "result_max_bytes": 200000,
        "servers": []
    },

    "_skills_comment": "Runtime-extensible skill loader. user_skills_dir is the path the SkillRegistry walks at startup; each *.py file under it is imported and may call harness.skills.register(MySkill(...)) to add a ToolSkill / PipelineSkill / SubAgentSkill that the planner can invoke. Failures (syntax error, missing import) are logged and skipped — one bad file doesn't take down startup. Default ~/.harness/skills.",
    "skills": {
        "user_skills_dir": "~/.harness/skills"
    },

    "_memory_comment": "Per-repository session memory. When enabled=true (default), the planner reads the prior-session log (~/.harness/memory/<repo_id>.md) at the start of every harness run and injects the most recent entries as system context, and cmd_run appends a fresh entry on exit. Repo identity = SHA-256 of `git remote get-url origin` if available, else the workspace path. max_bytes caps the file itself (FIFO trim drops oldest sections). inject_max_bytes caps what the planner sees on each run.",
    "memory": {
        "enabled": true,
        "dir": "~/.harness/memory",
        "max_bytes": 100000,
        "inject_max_bytes": 8000
    },

    "_github_comment": "GitHub integration. Subcommands (harness gh issue / pr-create / pr-comment) shell out to the `gh` CLI; auth is whatever `gh auth status` shows. Set gh_path to point at a non-PATH `gh` binary if needed.",
    "github": {
        "gh_path": ""
    },

    "_repo_index_comment": "Repository semantic-retrieval index. Build with `harness index build`; when enabled, the planner queries the index for top-K chunks relevant to the user prompt and injects them as a system context block. backend = 'tfidf' (zero-dep, pure Python, default) or 'openai_embeddings' (requires OPENAI_API_KEY; falls back to tfidf on missing key). chunk_lines / chunk_overlap shape the per-file slicing; top_k bounds the retrieval set; inject_max_bytes caps the planner injection. index_dir is the SQLite store. exclude_globs and text_extensions tune the file walker.",
    "repo_index": {
        "enabled": false,
        "backend": "tfidf",
        "top_k": 5,
        "chunk_lines": 200,
        "chunk_overlap": 20,
        "inject_max_bytes": 4000,
        "index_dir": "~/.harness/repo_index"
    }
}
